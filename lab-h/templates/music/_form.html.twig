{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
    {% for field in form %}
        {% if field.vars.block_prefixes is defined and 'hidden' not in field.vars.block_prefixes %}
            <div class="mb-3 form-group">
                {{ form_label(field, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(field, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(field) }}
            </div>
        {% else %}
            {{ form_widget(field) }}
        {% endif %}
    {% endfor %}
    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary">{{ button_label|default('Save') }}</button>
        <a href="{{ path('app_music_index') }}" class="btn btn-outline-secondary">Cancel</a>
    </div>
{{ form_end(form) }}
