{% extends 'base.html.twig' %}

{% block title %}Edit Music{% endblock %}

{% block body %}
    <div class="mb-4">
        <h1>Edit Music</h1>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">Edit Record</div>
                <div class="card-body">
                    {{ include('music/_form.html.twig', {'button_label': 'Update'}) }}
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a href="{{ path('app_music_index') }}" class="btn btn-outline-secondary">Back to list</a>
    </div>

    <div class="mt-3">
        {{ include('music/_delete_form.html.twig') }}
    </div>
{% endblock %}
