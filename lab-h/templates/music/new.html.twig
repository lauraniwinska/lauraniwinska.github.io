{% extends 'base.html.twig' %}

{% block title %}New Music{% endblock %}

{% block body %}
    <div class="mb-4">
        <h1>Create New Music</h1>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">New Record</div>
                <div class="card-body">
                    {{ include('music/_form.html.twig', {'button_label': 'Create'}) }}
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a href="{{ path('app_music_index') }}" class="btn btn-outline-secondary">Back to list</a>
    </div>
{% endblock %}
